# ── Local config (machine-specific paths) ────────────────────────────────────
config.yaml

# ── External data (too large for GitHub) ─────────────────────────────────────
# All generated protein data lives outside the repo in data_root (see config.yaml)
# If you have a local data/ folder with large files, add patterns here:
data/raw/
data/pqr/
data/apbs/
data/esp/
data/meshes/
data/vtk/
data/sampled/
data/timing.csv
data/pipeline.log

# Keep the small reference dataset (9 proteins for notebooks)
# Add explicit exceptions here if needed:
# !data/raw/AF_Q16613.pdb

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Conda / virtual environments ──────────────────────────────────────────────
.env
.venv
env/
venv/
ENV/

# ── Logs and outputs ──────────────────────────────────────────────────────────
logs/
outputs/figures/
outputs/metrics/
*.log

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.Zone.Identifier

# ── IDE files ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Testing and coverage ──────────────────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
.mypy_cache/

# ── Model checkpoints ─────────────────────────────────────────────────────────
*.pt
*.pth
*.ckpt
*.h5

